<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= pet.name %> - Pet Adoption System</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <%- include('partials/nav', { user }) %>

  <main class="container">
    <section class="page-header">
      <div>
        <p class="eyebrow">Pet Profile</p>
        <h1><%= pet.name %></h1>
        <p><%= pet.species %> record managed by authorized shelter users.</p>
      </div>
      <div class="header-actions">
        <a class="btn btn-warning" href="/pets/<%= pet.id %>/edit">Edit</a>
        <a class="btn btn-light" href="/pets">Back</a>
      </div>
    </section>

    <section class="detail-layout">
      <article class="panel">
        <div class="profile-top">
          <div class="pet-avatar"><%= pet.name.charAt(0).toUpperCase() %></div>
          <div>
            <h2><%= pet.name %></h2>
            <span class="badge <%= pet.status.toLowerCase() %>"><%= pet.status %></span>
          </div>
        </div>

        <dl class="detail-list">
          <div><dt>Species</dt><dd><%= pet.species %></dd></div>
          <div><dt>Breed</dt><dd><%= pet.breed || 'N/A' %></dd></div>
          <div><dt>Age</dt><dd><%= pet.age !== null ? pet.age : 'N/A' %></dd></div>
          <div><dt>Gender</dt><dd><%= pet.gender %></dd></div>
          <div><dt>Size</dt><dd><%= pet.size %></dd></div>
          <div><dt>Color</dt><dd><%= pet.color || 'N/A' %></dd></div>
          <div><dt>Health</dt><dd><%= pet.health_status || 'N/A' %></dd></div>
        </dl>

        <div class="notes-box">
          <h3>Description</h3>
          <p><%= pet.description || 'No description provided.' %></p>
        </div>
      </article>

      <aside class="panel">
        <% if (pet.status === 'Available') { %>
          <h2>Mark as Adopted</h2>
          <p class="muted">Record the adopter details once the adoption is completed.</p>

          <form method="POST" action="/pets/<%= pet.id %>/adopt">
            <label>Adopter Name</label>
            <input type="text" name="adopter_name" required>

            <label>Adopter Contact</label>
            <input type="text" name="adopter_contact" required>

            <button class="btn btn-block" type="submit">Mark Adopted</button>
          </form>
        <% } else { %>
          <h2>Adoption Details</h2>
          <dl class="detail-list compact">
            <div><dt>Adopter</dt><dd><%= pet.adopter_name || 'N/A' %></dd></div>
            <div><dt>Contact</dt><dd><%= pet.adopter_contact || 'N/A' %></dd></div>
            <div><dt>Date</dt><dd><%= pet.adoption_date ? String(pet.adoption_date).slice(0, 10) : 'N/A' %></dd></div>
          </dl>

          <form method="POST" action="/pets/<%= pet.id %>/available">
            <button class="btn btn-warning btn-block" type="submit">Mark Available Again</button>
          </form>
        <% } %>

        <% if (user.role === 'admin') { %>
          <form class="danger-zone" method="POST" action="/pets/<%= pet.id %>?_method=DELETE">
            <button class="btn btn-danger btn-block" onclick="return confirm('Delete this pet record?')" type="submit">Delete Record</button>
          </form>
        <% } %>
      </aside>
    </section>
  </main>
</body>
</html>
