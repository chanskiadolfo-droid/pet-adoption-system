<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Edit <%= pet.name %> - Pet Adoption System</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <%- include('partials/nav', { user }) %>

  <main class="container narrow">
    <section class="page-header">
      <div>
        <p class="eyebrow">Update Record</p>
        <h1>Edit <%= pet.name %></h1>
        <p>Modify pet details and adoption information.</p>
      </div>
    </section>

    <section class="panel">
      <form method="POST" action="/pets/<%= pet.id %>?_method=PUT" class="record-form">
        <div class="form-grid">
          <div>
            <label>Pet Name</label>
            <input type="text" name="name" value="<%= pet.name %>" required>
          </div>
          <div>
            <label>Species</label>
            <input type="text" name="species" value="<%= pet.species %>" required>
          </div>
          <div>
            <label>Breed</label>
            <input type="text" name="breed" value="<%= pet.breed || '' %>">
          </div>
          <div>
            <label>Age</label>
            <input type="number" name="age" value="<%= pet.age !== null ? pet.age : '' %>" min="0">
          </div>
          <div>
            <label>Gender</label>
            <select name="gender" required>
              <option value="Male" <%= pet.gender === 'Male' ? 'selected' : '' %>>Male</option>
              <option value="Female" <%= pet.gender === 'Female' ? 'selected' : '' %>>Female</option>
            </select>
          </div>
          <div>
            <label>Size</label>
            <select name="size" required>
              <option value="Small" <%= pet.size === 'Small' ? 'selected' : '' %>>Small</option>
              <option value="Medium" <%= pet.size === 'Medium' ? 'selected' : '' %>>Medium</option>
              <option value="Large" <%= pet.size === 'Large' ? 'selected' : '' %>>Large</option>
            </select>
          </div>
          <div>
            <label>Color</label>
            <input type="text" name="color" value="<%= pet.color || '' %>">
          </div>
          <div>
            <label>Health Status</label>
            <input type="text" name="health_status" value="<%= pet.health_status || '' %>">
          </div>
          <div>
            <label>Status</label>
            <select name="status" required>
              <option value="Available" <%= pet.status === 'Available' ? 'selected' : '' %>>Available</option>
              <option value="Adopted" <%= pet.status === 'Adopted' ? 'selected' : '' %>>Adopted</option>
            </select>
          </div>
          <div>
            <label>Adoption Date</label>
            <input type="date" name="adoption_date" value="<%= pet.adoption_date ? String(pet.adoption_date).slice(0, 10) : '' %>">
          </div>
          <div>
            <label>Adopter Name</label>
            <input type="text" name="adopter_name" value="<%= pet.adopter_name || '' %>">
          </div>
          <div>
            <label>Adopter Contact</label>
            <input type="text" name="adopter_contact" value="<%= pet.adopter_contact || '' %>">
          </div>
        </div>

        <label>Description</label>
        <textarea name="description"><%= pet.description || '' %></textarea>

        <div class="form-actions">
          <button class="btn" type="submit">Update Pet</button>
          <a class="btn btn-light" href="/pets/<%= pet.id %>">Cancel</a>
        </div>
      </form>
    </section>
  </main>
</body>
</html>
