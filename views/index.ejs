<section class="page-head">
  <div>
    <h1>Pet Records</h1>
    <p>Track available and adopted pets for shelter staff and adoption centers.</p>
  </div>
  <a class="button-link" href="/pets/new">Add Pet</a>
</section>
<section class="stats-grid">
  <div class="stat">
    <span>Total Pets</span>
    <strong><%= summary.total || 0 %></strong>
  </div>
  <div class="stat">
    <span>Available</span>
    <strong><%= summary.available || 0 %></strong>
  </div>
  <div class="stat">
    <span>Adopted</span>
    <strong><%= summary.adopted || 0 %></strong>
  </div>
</section>
<form class="filters" action="/pets" method="GET">
  <input type="search" name="search" value="<%= filters.search %>" placeholder="Search name, type, or breed">
  <select name="status">
    <option value="all" <%= filters.status === 'all' ? 'selected' : '' %>>All Pets</option>
    <option value="Available" <%= filters.status === 'Available' ? 'selected' : '' %>>Available</option>
    <option value="Adopted" <%= filters.status === 'Adopted' ? 'selected' : '' %>>Adopted</option>
  </select>
  <button type="submit">Filter</button>
</form>
<section class="panel table-wrap">
  <table>
    <thead>
      <tr>
        <th>Name</th>
        <th>Type</th>
        <th>Breed</th>
        <th>Age</th>
        <th>Gender</th>
        <th>Status</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% if (!pets.length) { %>
        <tr>
          <td colspan="7" class="empty">No pet records found.</td>
        </tr>
      <% } %>
      <% pets.forEach((pet) => { %>
        <tr>
          <td>
            <strong><%= pet.name %></strong>
            <% if (pet.description) { %>
              <small><%= pet.description %></small>
            <% } %>
          </td>
          <td><%= pet.type %></td>
          <td><%= pet.breed || 'N/A' %></td>
          <td><%= pet.age || 'N/A' %></td>
          <td><%= pet.gender %></td>
          <td>
            <span class="badge <%= pet.adoption_status === 'Adopted' ? 'adopted' : 'available' %>">
              <%= pet.adoption_status %>
            </span>
          </td>
          <td class="actions">
            <a href="/pets/<%= pet.id %>/edit">Edit</a>
            <% if (pet.adoption_status === 'Available') { %>
              <form action="/pets/<%= pet.id %>/adopt" method="POST">
                <button type="submit">Mark Adopted</button>
              </form>
            <% } else { %>
              <form action="/pets/<%= pet.id %>/available" method="POST">
                <button type="submit">Set Available</button>
              </form>
            <% } %>
            <form action="/pets/<%= pet.id %>/delete" method="POST" onsubmit="return confirm('Delete this pet record?');">
              <button class="danger" type="submit">Delete</button>
            </form>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</section>