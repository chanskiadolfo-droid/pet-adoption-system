<section class="page-head">
  <div>
    <h1><%= title %></h1>
    <p>Enter accurate pet details for adoption tracking.</p>
  </div>
  <a class="button-link secondary" href="/pets">Back</a>
</section>
<form class="panel pet-form" action="<%= action %>" method="POST">
  <div class="form-grid">
    <div>
      <label>Pet Name</label>
      <input name="name" value="<%= pet.name || '' %>" required>
    </div>
    <div>
      <label>Type</label>
      <input name="type" value="<%= pet.type || '' %>" placeholder="Dog, Cat, Rabbit" required>
    </div>
    <div>
      <label>Breed</label>
      <input name="breed" value="<%= pet.breed || '' %>">
    </div>
    <div>
      <label>Age</label>
      <input type="number" min="0" name="age" value="<%= pet.age || '' %>">
    </div>
    <div>
      <label>Gender</label>
      <select name="gender" required>
        <option value="Male" <%= pet.gender === 'Male' ? 'selected' : '' %>>Male</option>
        <option value="Female" <%= pet.gender === 'Female' ? 'selected' : '' %>>Female</option>
        <option value="Unknown" <%= pet.gender === 'Unknown' ? 'selected' : '' %>>Unknown</option>
      </select>
    </div>
    <div>
      <label>Adoption Status</label>
      <select name="adoption_status" required>
        <option value="Available" <%= pet.adoption_status === 'Available' || !pet.adoption_status ? 'selected' : '' %>>Available</option>
        <option value="Adopted" <%= pet.adoption_status === 'Adopted' ? 'selected' : '' %>>Adopted</option>
      </select>
    </div>
  </div>
  <label>Description</label>
  <textarea name="description" rows="5"><%= pet.description || '' %></textarea>
  <button type="submit"><%= submitLabel %></button>
</form>